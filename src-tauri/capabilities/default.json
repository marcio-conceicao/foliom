{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability default para Foliom desktop",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save"
  ],
  "remote": {
    "urls": ["http://127.0.0.1:*/**"]
  }
}
